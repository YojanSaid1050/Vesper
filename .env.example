# ============================================
# Vesper Bot - Configuración
# ============================================

# Discord
TOKEN=tu_token_discord_aqui
CLIENT_ID=tu_client_id_aqui
GUILD_ID=tu_guild_id_aqui_opcional

# Twitch API
TWITCH_CLIENT_ID=tu_twitch_client_id
TWITCH_CLIENT_SECRET=tu_twitch_client_secret

# Apify (para TikTok)
APIFY_TOKEN=tu_apify_token

# YouTube API
YOUTUBE_API_KEY=tu_youtube_api_key

# MongoDB
MONGODB_URI=tu_mongodb_uri

# ============================================
# Configuración del Bot
# ============================================

# Usar comandos locales (true) o globales (false)
USE_GUILD_COMMANDS=true

# Puerto para el servidor web
PORT=3000

# Debug (opcional)
DEBUG=false
LOG_ERRORS=true

# Rutas (opcional)
DATA_PATH=./data
LOGS_PATH=./logs